import cv2

# Step 1: Read the image
img = cv2.imread("image.jpg")

# Step 2: Check if image is loaded properly
if img is None:
    print("Error: Image not found!")
else:
    # Step 3: Rotate 90 degrees clockwise
    rotated = cv2.rotate(img, cv2.ROTATE_90_CLOCKWISE)

    # Step 4: Display original and rotated images
    cv2.imshow("Original Image", img)
    cv2.imshow("90 Degree Clockwise Rotated Image", rotated)

    # Step 5: Wait for key press
    cv2.waitKey(0)

    # Step 6: Close all windows
    cv2.destroyAllWindows()
